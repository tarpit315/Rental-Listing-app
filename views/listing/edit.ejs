<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Listing</title>
    <link rel="stylesheet" href="/style.css">

</head>
<body>
  <% layout("layout/plate") %>

  <div class="form-wrapper">
    <div class="form-card">
  
      <h1>Edit Listing</h1>
  
      <form method="POST" action="/listing/<%= listing._id %>?_method=PUT">
  
        <div class="group">
          <label for="title">Title</label>
          <input
            id="title"
            type="text"
            name="title"
            value="<%= listing.title %>"
            required>
        </div>
  
        <div class="group">
          <label for="description">Description</label>
          <textarea
            id="description"
            name="description"
            required><%= listing.description %></textarea>
        </div>
  
        <div class="group">
          <label for="image">Image URL</label>
          <input
            id="image"
            type="text"
            name="image[url]"
            value="<%= listing.image.url %>">
        </div>
  
        <div class="group two-col">
  
          <div>
            <label for="price">Price</label>
            <input
              id="price"
              type="number"
              name="price"
              value="<%= listing.price %>"
              required>
          </div>
  
          <div>
            <label for="location">Location</label>
            <input
              id="location"
              type="text"
              name="location"
              value="<%= listing.location %>"
              required>
          </div>
  
        </div>
  
        <div class="group">
          <label for="country">Country</label>
          <input
            id="country"
            type="text"
            name="country"
            value="<%= listing.country %>"
            required>
        </div>
  
        <button class="submit-btn" type="submit">Update Listing</button>
  
      </form>
  
      <a class="back-link" href="/listing/<%= listing._id %>">← Back to Details</a>
  
    </div>
  </div>
</html>