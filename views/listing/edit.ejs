<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Listing</title>
    <link rel="stylesheet" href="/edit.css">

</head>
<body>

<div class="container">
  <h1>Edit Listing</h1>

  <form method="POST" action="/listing/<%= listing._id %>?_method=PUT">
    <div class="group">
      <label>Title</label>
      <input 
        type="text" 
        name="title" 
        value="<%= listing.title %>" 
        required>
    </div>
<br>
    <div class="group">
      <label>Description</label>
      <textarea 
        name="description" 
        required><%= listing.description %></textarea>
    </div>
<br>
    <div class="group">
      <label>Image URL</label>
      <input 
        type="text" 
        name="image[url]" 
        value="<%= listing.image.url %>">
    </div>
<br>
    <div class="group">
      <label>Price</label>
      <input 
        type="number" 
        name="price" 
        value="<%= listing.price %>" 
        required>
    </div>
<br>
    <div class="group">
      <label>Location</label>
      <input 
        type="text" 
        name="location" 
        value="<%= listing.location %>" 
        required>
    </div>
<br>
    <div class="group">
      <label>Country</label>
      <input 
        type="text" 
        name="country" 
        value="<%= listing.country %>" 
        required>
    </div>
<br>
    <button type="submit"  >Update Listing</button>
  </form>
<br>
  <a href="/listing/<%= listing._id %>">← Back to Details</a>
</div>

</body>
</html>