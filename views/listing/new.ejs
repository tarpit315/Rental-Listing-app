<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Listing</title>
  <link rel="stylesheet" href="/style.css">
<% layout("layout/plate") %>

<div class="form-wrapper">
  <div class="form-card">
    <h1>Create New Listing</h1>

    <form action="/listing" method="POST">

      <div class="group">
        <label for="title">Title</label>
        <input id="title" type="text" name="listing[title]" required>
      </div>

      <div class="group">
        <label for="description">Description</label>
        <textarea id="description" name="listing[description]" required></textarea>
      </div>

      <div class="group">
        <label for="image">Image URL</label>
        <input id="image" type="text" name="listing[image][url]">
      </div>

      <div class="group two-col">
        <div>
          <label for="price">Price</label>
          <input id="price" type="number" name="listing[price]" required>
        </div>

        <div>
          <label for="location">Location</label>
          <input id="location" type="text" name="listing[location]" required>
        </div>
      </div>

      <div class="group">
        <label for="country">Country</label>
        <input id="country" type="text" name="listing[country]" required>
      </div>

      <button class="submit-btn" type="submit">Create Listing</button>
    </form>
  </div>
</div>
</html>