<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Listing</title>
  <link rel="stylesheet" href="/new.css">
  
</head>
<body>

<div class="container">
  <h1>Create New Listing</h1>

  <form action="/listing" method="POST">

    <div class="group">
      <label>Title</label>
      <input type="text" name="listing[title]" required>
    </div>
    <br>
    <div class="group">
      <label>Description</label>
      <textarea name="listing[description]" required></textarea>
    </div>
    <br>
    <div class="group">
      <label>Image URL</label>
      <input type="text" name="listing[image[url]]">
    </div>
    <br>
    <div class="group">
      <label>Price</label>
      <input type="number" name="listing[price]" required>
    </div>
    <br>
    <div class="group">
      <label>Location</label>
      <input type="text" name="listing[location]" required>
    </div>
    <br>
    <div class="group">
      <label>Country</label>
      <input type="text" name="listing[country]" required>
    </div>
    <br>
    <button type="submit">Create Listing</button>
  </form>
</div>

</body>
</html>