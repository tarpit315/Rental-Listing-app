<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= listing.title %></title>
    <link rel="stylesheet" href="/show.css">
    <% layout("/layout/plate") -%>
</head>
<body>

  <div class="container">

    <img src="<%= listing.image.url %>" alt="listing image">

    <div class="content">
      <h1><%= listing.title %></h1>

      <p><%= listing.description %></p>

      <p class="price">₹ <%= listing.price.toLocaleString("en-IN") %></p> 

      <p class="location">
        <%= listing.location %>, <%= listing.country %>
      </p>

      <a href="/listing">← Back to Listings</a>
    </div>

  </div>
  <a href="/listing/<%= listing._id %>/edit">Edit</a>
<br><br>
  <form method="post" action="/listing/<%=listing._id%>?_method=DELETE">
    <button class="del">DELETE THIS LISTING</button>
  </form>
</body>
</html>